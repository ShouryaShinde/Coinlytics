<%- include("partials/header.ejs") %>

<div class="headings">
  <h3>Search Results</h3>
  <p class="text-body-secondary">
    Most relevant search results for "<%= searchText %>"
  </p>
</div>
<% if (coindata && coindata.length > 0) { %>
<table class="crypto-table">
<thead class="table-header">
<tr class="table-row">
<th class="table-head">#</th>
<th class="table-head">Name</th>
<th class="table-head">Coin ID</th>
<th class="table-head">Rank</th>
</tr>
</thead>
<tbody class="table-body">
<% for (let i = 0; i < Math.min(coindata.length, 10); i++) { %>
<tr class="table-row clickable">
<td class="table-cell"><%= i + 1 %></td>
<td class="table-cell">
<a method="GET" href="/coin/<%= coindata[i].id %>">
<div class="crypto-name">
<div class="coin-icon">

  <img
    src="https://cryptoicon-api.pages.dev/api/icon/<%= coindata[i].symbol.toLowerCase() %>"
    alt="<%= coindata[i].name %>"
    class="coin-image"
    onerror="this.parentElement.classList.add('icon-fallback')"
  >

  <div class="coin-avatar">
    <%= coindata[i].symbol ? coindata[i].symbol.toUpperCase() : "CR" %>
  </div>

</div>
<div class="name-info">
<span class="symbol">
<%= coindata[i].symbol ? coindata[i].symbol.toUpperCase() : "N/A" %>
</span>
<span class="name-text">
<%= coindata[i].name || "Unknown Coin" %>
</span>
</div>
</div>
</a>
</td>
<td class="table-cell">
<%= coindata[i].id || "N/A" %>
</td>
<td class="table-cell">
<%= coindata[i].rank || "N/A" %>
</td>
</tr>
<% } %>
</tbody>
</table>
<% } else { %>
<h4>No search result for "<%= searchText %>"</h4>
<% } %>

<%- include("partials/footer.ejs") %>
