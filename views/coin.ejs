<%- include("partials/header.ejs") %>

<div class="coin-details">
<div class="coin-icon">

  <img
    src="https://cryptoicon-api.pages.dev/api/icon/<%= coin.symbol.toLowerCase() %>"
    alt="<%= coin.name %>"
    class="coin-image"
    onerror="this.parentElement.classList.add('icon-fallback')"
  >

  <div class="coin-avatar">
    <%= coin.symbol ? coin.symbol.toUpperCase() : "CR" %>
  </div>

</div>
<div class="coin-name-info">
<span class="coin-symbol">
<%= coin?.symbol ? coin.symbol.toUpperCase() : "N/A" %>
</span>
<span class="coin-name">
<%= coin?.name || "Unknown Coin" %>
</span>
</div>
</div>
<div class="Spacing"></div>
<div>
<table class="crypto-table">
<thead class="table-header">
<tr class="table-row">
<th class="table-head">Label</th>
<th class="table-head">Value</th>
</tr>
</thead>
<tbody class="table-body">
<tr class="table-row">
<td class="table-cell">Market Cap</td>
<td class="table-cell">
<%= coin?.quotes?.USD?.market_cap
? Intl.NumberFormat("en-US",{
style:"currency",
currency:"USD",
notation:"compact",
maximumFractionDigits:2
}).format(coin.quotes.USD.market_cap)
: "N/A" %>
</td>
</tr>
<tr class="table-row">
<td class="table-cell">Total Volume</td>
<td class="table-cell">
<%= coin?.quotes?.USD?.volume_24h
? Intl.NumberFormat("en-US",{
style:"currency",
currency:"USD",
notation:"compact",
maximumFractionDigits:2
}).format(coin.quotes.USD.volume_24h)
: "N/A" %>
</td>
</tr>
<tr class="table-row">
<td class="table-cell">Price</td>
<td class="table-cell">
<%= coin?.quotes?.USD?.price
? Intl.NumberFormat("en-US",{
style:"currency",
currency:"USD",
notation:"compact",
maximumFractionDigits:2
}).format(coin.quotes.USD.price)
: "N/A" %>
</td>
</tr>
<tr class="table-row">
<td class="table-cell">24h Change</td>
<% if (coin?.quotes?.USD?.percent_change_24h > 0) { %>
<td class="table-cell positive">
<div class="trend positive">
<i class="bi bi-graph-up-arrow"></i>
+<%= coin.quotes.USD.percent_change_24h.toFixed(2) %>%
</div>
</td>
<% } else { %>
<td class="table-cell negative">
<div class="trend negative">
<i class="bi bi-graph-down-arrow"></i>
<%= coin?.quotes?.USD?.percent_change_24h
? coin.quotes.USD.percent_change_24h.toFixed(2)
: "0" %>%
</div>
</td>
<% } %>
</tr>
<tr class="table-row">
<td class="table-cell">Circulating Supply</td>
<td class="table-cell">
<%= coin?.circulating_supply
? Intl.NumberFormat("en-US",{
notation:"compact",
maximumFractionDigits:2
}).format(coin.circulating_supply)
: "N/A" %>
</td>
</tr>
<tr class="table-row">
<td class="table-cell">Total Supply</td>
<td class="table-cell">

<%= coin?.total_supply
? Intl.NumberFormat("en-US",{
notation:"compact",
maximumFractionDigits:2
}).format(coin.total_supply)
: "N/A" %>
</td>
</tr>
<tr class="table-row">
<td class="table-cell">Max Supply</td>
<td class="table-cell">
<%= coin?.max_supply
? Intl.NumberFormat("en-US",{
notation:"compact",
maximumFractionDigits:2
}).format(coin.max_supply)
: "N/A" %>
</td>
</tr>
<tr class="table-row">
<td class="table-cell">Rank</td>
<td class="table-cell">
<%= coin?.rank || "N/A" %>
</td>
</tr>
</tbody>
</table>
</div>

<%- include("partials/footer.ejs") %>
