<%- include("partials/header.ejs") %>

<div class="headings">
  <h1>Dashboard</h1>
  <p class="text-body-secondary">Track real-time cryptocurrency prices and market trends</p>
</div>
<div class="Dashboard Cards GridParent">
  <!-- Card 1 : Total Market Cap -->
  <div class="crypto-card">
    <div class="card-header">

  <div class="icon-wrapper">
    <i class="bi bi-currency-dollar custom-icon"></i>
  </div>
  <% if (global && global.market_cap_change_24h !== undefined) { %>
    <% if (global.market_cap_change_24h > 0) { %>
    <div class="trend positive">
      <i class="bi bi-graph-up-arrow"></i>
      +<%= Intl.NumberFormat("en-US",{maximumFractionDigits:2}).format(global.market_cap_change_24h) %>%
    </div>
    <% } else { %>
    <div class="trend negative">
      <i class="bi bi-graph-down-arrow"></i>
      <%= Intl.NumberFormat("en-US",{maximumFractionDigits:2}).format(global.market_cap_change_24h) %>%
    </div>
    <% } %>
  <% } else { %>
  <div class="trend neutral text-muted">
    <i class="bi bi-question-circle"></i>
    Data unavailable
  </div>
  <% } %>
</div>
<p class="card-label">Total Market Cap</p>
<p class="card-value">
  <%= global && global.market_cap_usd
  ? Intl.NumberFormat("en-US",{
    style:"currency",
    currency:"USD",
    notation:"compact",
    maximumFractionDigits:2
  }).format(global.market_cap_usd)
  : "Data unavailable" %>
</p>
  </div>

  <!-- Card 2 : 24h Volume -->

  <div class="crypto-card">
<div class="card-header">
  <div class="icon-wrapper">
    <i class="bi bi-activity custom-icon"></i>
  </div>
</div>
<p class="card-label">24h Volume</p>
<p class="card-value">
  <%= global && global.volume_24h_usd
  ? Intl.NumberFormat("en-US",{
    style:"currency",
    currency:"USD",
    notation:"compact",
    maximumFractionDigits:2
  }).format(global.volume_24h_usd)
  : "Data unavailable" %>
</p>
  </div>

  <!-- Card 3 : BTC Dominance -->

  <div class="crypto-card">
<div class="card-header">
  <div class="icon-wrapper">
    <i class="bi bi-currency-bitcoin custom-icon"></i>
  </div>
</div>
<p class="card-label">BTC Dominance</p>
<p class="card-value">
  <%= global && global.bitcoin_dominance_percentage
  ? Intl.NumberFormat("en-US",{
    maximumFractionDigits:2
  }).format(global.bitcoin_dominance_percentage) + "%"
  : "Data unavailable" %>
</p>
  </div>

  <!-- Card 4 : Fear and Greed Index -->

  <div class="crypto-card">
<div class="card-header">
  <div class="icon-wrapper">
    <i class="bi bi-heart-pulse custom-icon"></i>
  </div>
  <% let color=""; let iconClass="";
  if (parseInt(fng.value) <= 24) {
  color='#d9534f'; iconClass="bi-graph-down-arrow";
  } else if (parseInt(fng.value) <= 50) {
  color='#f0ad4e'; iconClass="bi-graph-down-arrow";
  } else if (parseInt(fng.value) <= 54) {
  color='#5bc0de'; iconClass="bi-graph-down-arrow";
  } else if (parseInt(fng.value) <= 74) {
  color='#5cb85c'; iconClass="bi-graph-up-arrow";
  } else {
  color="#28a745"; iconClass="bi-graph-up-arrow";
  } %>
  <div class="trend positive">
    <i class="bi <%= iconClass %>" style="color:<%= color %>"></i>
    <span style="color:<%= color %>">
      <%= fng.value_classification %>
    </span>
  </div>
</div>
<p class="card-label">Fear and Greed Index</p>
<p class="card-value">
  <%= fng.value %>
</p>
  </div>
</div>
<!-- Top Coins Table -->
<div class="headings paddingh2">
<h2>Top Cryptocurrencies</h2>
<div class="crypto-table-wrapper">
<table class="crypto-table">
<thead class="table-header">
<tr class="table-row">
<th class="table-head">Rank</th>
<th class="table-head">Name</th>
<th class="table-head">Price</th>
<th class="table-head">24h %</th>
<th class="table-head">Market Cap</th>
<th class="table-head">Volume</th>
</tr>
</thead>
<tbody class="table-body">
<% for (let i = 0; i < coin.length; i++) { %>
<tr class="table-row clickable">
<td class="table-cell"><%= coin[i].rank %></td>
<td class="table-cell">
<a method="GET" href="/coin/<%=coin[i].id%>">
<div class="crypto-name">
<div class="coin-icon">
  <img
    src="https://cryptoicon-api.pages.dev/api/icon/<%= coin[i].symbol.toLowerCase() %>"
    alt="<%= coin[i].name %>"
    class="coin-image"
    onerror="this.parentElement.classList.add('icon-fallback')"
  >
  <div class="coin-avatar">
    <%= coin[i].symbol ? coin[i].symbol.toUpperCase() : "CR" %>
  </div>
</div>
<div class="name-info">
<span class="symbol"><%= coin[i].symbol.toUpperCase() %></span>
<span class="name-text"><%= coin[i].name %></span>
</div>
</div>
</a>
</td>
<td class="table-cell">
<%= Intl.NumberFormat("en-US",{
style:"currency",
currency:"USD",
notation:"compact",
maximumFractionDigits:2
}).format(coin[i].quotes.USD.price) %>
</td>
<% if (coin[i].quotes.USD.percent_change_24h > 0) { %>
<td class="table-cell positive">
<div class="trend positive">
<i class="bi bi-graph-up-arrow"></i>
+<%= coin[i].quotes.USD.percent_change_24h.toFixed(2) %>%
</div>
</td>
<% } else { %>
<td class="table-cell negative">
<div class="trend negative">
<i class="bi bi-graph-down-arrow"></i>
<%= coin[i].quotes.USD.percent_change_24h.toFixed(2) %>%
</div>
</td>
<% } %>
<td class="table-cell">
<%= Intl.NumberFormat("en-US",{
style:"currency",
currency:"USD",
notation:"compact",
maximumFractionDigits:2
}).format(coin[i].quotes.USD.market_cap) %>
</td>
<td class="table-cell">
<%= Intl.NumberFormat("en-US",{
style:"currency",
currency:"USD",
notation:"compact",
maximumFractionDigits:2
}).format(coin[i].quotes.USD.volume_24h) %>
</td>
</tr>
<% } %>
</tbody>
</table>
</div>
</div>

<%- include("partials/footer.ejs") %>
